<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Restaurant de la Chalaronne – Cuisine traditionnelle à Saint-Didier-sur-Chalaronne{% endblock %}</title>

        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        <meta name="description" content="{% block meta_description %}Découvrez le Restaurant de la Chalaronne à Saint-Didier-sur-Chalaronne. Une cuisine maison, conviviale et authentique, idéale pour vos repas en famille, entre amis ou en couple.{% endblock %}">

        <meta name="keywords" content="Restaurant de la Chalaronne, Restaurant Saint-Didier-sur-Chalaronne, Restaurant Ain, Restaurant traditionnel Ain, Cuisine maison Ain, Restaurant convivial Ain, Restaurant famille Ain, Restaurant proche Bresse, Où manger Saint-Didier-sur-Chalaronne, Restaurant terrasse Ain, Restaurant local Ain, Cuisine française Ain, Restaurant fait maison, Repas en famille Ain, Restaurant entre amis Ain, Restaurant proche Lyon, Restaurant dans l’Ain, Restaurant avec terrasse, Restaurant chaleureux, Restaurant près rivière Chalaronne, Restaurant du camping Chalaronne, Restaurant Bresse Ain, Sortir manger Ain Rhône-Alpes">

        <!-- Open Graph (Facebook / LinkedIn / WhatsApp) -->
        <meta property="og:title" content="{% block og_title %}Restaurant de la Chalaronne – Cuisine traditionnelle et conviviale{% endblock %}">
        <meta property="og:description" content="{% block og_description %}Profitez d’un moment gourmand au Restaurant de la Chalaronne à Saint-Didier-sur-Chalaronne. Cuisine maison et ambiance chaleureuse au rendez-vous.{% endblock %}">
        <meta property="og:image" content="{% block og_image %}{{ asset('assets/images/logo_resto_chalaronne.png') }}{% endblock %}">
        <meta property="og:type" content="website">
        <meta property="og:url" content="{{ app.request.uri }}">

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="{% block twitter_title %}Restaurant de la Chalaronne – Cuisine traditionnelle{% endblock %}">
        <meta name="twitter:description" content="{% block twitter_description %}Découvrez une cuisine maison et conviviale au Restaurant de la Chalaronne à Saint-Didier-sur-Chalaronne.{% endblock %}">
        <meta name="twitter:image" content="{% block twitter_image %}{{ asset('assets/images/logo_resto_chalaronne.png') }}{% endblock %}">
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
            {# <link rel="stylesheet" href="{{ asset('assets/css/style.css') }}">
            <link rel="stylesheet" href="{{ asset('assets/css/bootstrap.css') }}">
            <link rel="stylesheet" href="{{ asset('assets/css/responsive.css') }}"> #}

            {# Favicon #}
            <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('assets/css/images/logo_camping_chalaronne_dark.png?v=2') }}">
            <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('assets/css/images/logo_camping_chalaronne_dark.png?v=2') }}">
            <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('assets/css/images/logo_camping_chalaronne_dark.png?v=2') }}">
            <link rel="shortcut icon" href="{{ asset('assets/css/images/logo_camping_chalaronne_dark.png?v=2') }}">
        {% endblock %}

        {% block javascripts %}
            {# Scripts globaux non-module #}
            <script src="{{ asset('assets/js/parallax.min.js') }}"></script>
            <script src="{{ asset('assets/js/wow.js') }}"></script>

            {# Bundle Webpack (jQuery + Bootstrap + Owl + Swiper + App.js) #}
            {{ encore_entry_script_tags('app') }}
            {# <script src="{{ asset('assets/js/jquery.js') }}"></script>
            <script src="{{ asset('assets/js/popper.min.js') }}"></script>
            <script src="{{ asset('assets/js/bootstrap.min.js') }}"></script>
            <script src="{{ asset('assets/js/jquery-ui.js') }}"></script>
            <script src="{{ asset('assets/js/jquery.fancybox.js') }}"></script>
            <script src="{{ asset('assets/js/swiper.js') }}"></script>
            <script src="{{ asset('assets/js/owl.js') }}"></script>
            <script src="{{ asset('assets/js/appear.js') }}"></script>
            <script src="{{ asset('assets/js/wow.js') }}"></script>
            <script src="{{ asset('assets/js/parallax.min.js') }}"></script>
            <script src="{{ asset('assets/js/custom-script.js') }}"></script> #}
        {% endblock %}
